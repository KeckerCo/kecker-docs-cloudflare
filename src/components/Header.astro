---
import { NAV_LINKS, SITE_TITLE } from '../consts';
---

<header>
  <nav class="nav-shell">
    <a class="brand" href="/" aria-label={SITE_TITLE}>
      <span class="brand-name">Kecker</span>
    </a>

    <button class="nav-toggle" id="navToggle" aria-label="Open navigation" aria-expanded="false">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <rect y="3" width="18" height="1.5" rx="0.75" fill="currentColor"/>
        <rect y="8" width="18" height="1.5" rx="0.75" fill="currentColor"/>
        <rect y="13" width="18" height="1.5" rx="0.75" fill="currentColor"/>
      </svg>
    </button>

    <div class="nav-links" id="navLinks">
      {NAV_LINKS.map((link) => (
        <a href={link.href} class={Astro.url.pathname === link.href ? 'active' : undefined}>
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('navToggle');
  const links = document.getElementById('navLinks');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    links?.classList.toggle('open');
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 249, 247, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #e0dbd5;
  }

  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 3.5rem;
  }

  .brand {
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-name {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.35rem;
    font-weight: 400;
    color: #111;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links a {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #666;
    text-decoration: none;
    transition: color 0.12s;
  }

  .nav-links a:hover { color: #111; }
  .nav-links a.active { color: #971b2f; }

  .nav-toggle {
    display: none;
    padding: 0.375rem;
    border: none;
    background: transparent;
    color: #666;
    cursor: pointer;
  }

  @media (max-width: 42rem) {
    .nav-shell { padding: 0 1rem; }
    .nav-toggle { display: flex; align-items: center; }

    .nav-links {
      display: none;
      position: absolute;
      top: 3.5rem;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: #faf9f7;
      border-bottom: 1px solid #e0dbd5;
      padding: 0.5rem 1rem 1rem;
      gap: 0;
    }

    .nav-links.open { display: flex; }

    .nav-links a {
      padding: 0.75rem 0;
      font-size: 0.9375rem;
      border-bottom: 1px solid #e0dbd5;
    }

    .nav-links a:last-child { border-bottom: none; }
  }
</style>
