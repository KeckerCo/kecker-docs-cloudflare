}

/* ── Responsive ──────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .biography-inner {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .portrait-aside {
    position: static;
    max-width: 280px;
  }
}

@media (max-width: 600px) {
  .biography-section,
  .name-section {
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .portrait-aside {
    max-width: 240px;
  }

  .works-list li {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto auto;
  }

  .work-year {
    grid-column: 1;
    grid-row: 2;
  }

  .work-desc {
    grid-row: 3;
  }
}
</style>
